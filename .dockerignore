# 依赖目录(容器内重新安装,不复制宿主的)
**/node_modules

# 构建产物(容器内重新构建)
**/.next
**/out
**/dist
**/build
**/.turbo

# 版本控制
.git
.gitignore
.gitattributes

# 环境变量(避免泄露到镜像层;运行时通过 docker env / compose 注入)
**/.env
**/.env.*
!**/.env.example

# 测试代码与产物(不进生产镜像)
admin/tests
**/coverage
**/test-results
**/playwright-report
**/.nyc_output

# IDE / 工具本地状态
.trae
.pai
.vscode
.idea
**/*.swp
**/*.swo

# 文档(非运行时必需)
docs
**/*.md

# Docker 自身(避免进入构建上下文)
Dockerfile
.dockerignore
**/docker-compose*.yml

# 日志与临时文件
**/*.log
**/*.tmp
**/.DS_Store
**/*.tsbuildinfo
**/next-env.d.ts

# Taro / 小程序本地缓存
**/.swc
**/.taro
