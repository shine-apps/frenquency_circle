# Local development env for frenqency_circle/admin
# Copy to .env and adjust as needed

# PostgreSQL — points to docker-compose service by default
DATABASE_URL="postgresql://frenqency:frenqency@localhost:5432/frenqency_circle"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-output-of-openssl-rand-base64-32"

# Required for non-HTTPS dev environments
AUTH_TRUST_HOST="true"

# --- Aliyun SMS (phone login) ---
# Leave ALIYUN_SMS_ACCESS_KEY_ID empty to enable dev console-logging fallback
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""
ALIYUN_SMS_ENDPOINT="dysmsapi.aliyuncs.com"

# Email domain auto-generated for phone-login users
PHONE_DOMAIN="phonedomain.com"

# SMS rate limits (optional overrides)
SMS_CODE_TTL_SECONDS="300"
SMS_CODE_MAX_ATTEMPTS="5"
SMS_RATE_PHONE_COOLDOWN_SECONDS="60"
SMS_RATE_PHONE_HOURLY="5"
SMS_RATE_IP_HOURLY="10"

# --- WeChat Mini-Program (phone login) ---
# From mp.weixin.qq.com → 开发管理 → 开发设置
WECHAT_MP_APP_ID=""
WECHAT_MP_APP_SECRET=""
WECHAT_MP_API_BASE="https://api.weixin.qq.com"

# --- Future OAuth providers (optional) ---
# To enable GitHub OAuth:
# 1. Create OAuth App at https://github.com/settings/developers
# 2. Set callback URL to http://localhost:3000/api/auth/callback/github
# 3. Fill these and uncomment:
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

