# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
/test-results/
/playwright-report/
/playwright/.cache/

# drizzle
# 注意:meta/_journal.json 与 meta/*_snapshot.json 是 drizzle-orm 运行时 migrator
# 必需的(不只是 drizzle-kit 生成器用),必须随 SQL 文件一起入库,
# 否则容器内 db/migrate.mjs 会报 "Can't find meta/_journal.json file"。

# user uploaded files (POST /api/upload)
/public/uploads/
